# ── Server ──
PORT=3000
NODE_ENV=development

# ── Database ──
DATABASE_URL="postgresql://postgres:password@localhost:5432/expense_tracker?schema=public"

# ── JWT ──
JWT_SECRET="your-jwt-access-secret-key"
JWT_EXPIRY="24h"
JWT_REFRESH_SECRET="your-jwt-refresh-secret-key"
JWT_REFRESH_EXPIRY="7d"

# ── AI Configuration ──
AI_PROVIDER=deepseek            # deepseek | openai | zhipu
AI_MODEL=deepseek-v4-pro        # deepseek-v4-pro | gpt-5 | gpt-4o | glm-5.1
AI_API_KEY=your-ai-api-key
AI_BASE_URL=                    # optional, custom endpoint
AI_TIMEOUT=15000                # ms
AI_DAILY_QUOTA=10               # maximum AI requests per user per day
AI_QUOTA_RESET_TIMEZONE=UTC     # timezone for daily quota reset (default: UTC 00:00)

# ── Storage ──
STORAGE_DRIVER=local            # local | s3
STORAGE_LOCAL_PATH=./uploads
AWS_S3_BUCKET=your-s3-bucket-name
AWS_S3_REGION=ap-southeast-1
AWS_S3_ACCESS_KEY=your-aws-access-key
AWS_S3_SECRET_KEY=your-aws-secret-key
AWS_S3_PRESIGNED_EXPIRY=900     # seconds (15 minutes)

# ── Email (SMTP) ──
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
MAIL_FROM=noreply@yourapp.com

# ── Firebase (FCM) ──
FCM_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# ── Logging ──
LOG_LEVEL=debug                 # error | warn | info | debug

# ── Rate Limiting ──
THROTTLE_TTL=60                 # seconds
THROTTLE_LIMIT=100              # default max requests per TTL

# ── App ──
APP_URL=http://localhost:3000   # base URL for email link generation
